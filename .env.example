REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=wsbanalyst scraper

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://localhost:8000

# Raw Reddit storage. Defaults to local SQLite when DATABASE_URL is omitted.
WSB_STORAGE=db
DATABASE_URL=sqlite:///wsb_data.sqlite3

FINBERT_MODEL=ProsusAI/finbert
FINBERT_BATCH_SIZE=4
MIN_TICKER_MENTIONS=3
MIN_TICKER_CONFIDENCE=0.65
TICKER_SENTIMENT_FILE=ticker_sentiment.json

WSB_CHAT_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
WSB_ENABLE_LOCAL_MODEL=false
WSB_BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
WSB_FINETUNED_DIR=wsb-mistral-finetuned2
WSB_TRAINING_DATA=wsb_training_data.jsonl
STOCK_CACHE_TTL_SECONDS=300
